# Variables d'environnement rubinotes — copier vers .env (gitignoré) et adapter.
# En production, TOUTES les valeurs sensibles doivent être définies ici
# (les valeurs par défaut de settings.py ne servent qu'au dev local).

DJANGO_SECRET_KEY=changez-moi-avec-une-vraie-cle-secrete
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
